<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/main_background">

    <!-- Fond avec dégradé -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/gradient_color_background" />

    <!-- ==================== En-tête ==================== -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:elevation="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Bouton retour -->
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="8dp"
            android:src="@drawable/ic_round_arrow_back_24"
            app:tint="@color/white" />

        <!-- Logo et titre -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Logo cinéma -->
            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_cinema_white"
                android:contentDescription="Theatron AI" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <!-- Titre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Theatron AI"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Sous-titre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Movie Assistant"
                    android:textColor="#B0BEC5"
                    android:textSize="11sp"
                    android:alpha="0.8" />
            </LinearLayout>
        </LinearLayout>

        <!-- Indicateur de chargement -->
        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone"
            android:indeterminateTint="#E94560" />

        <!-- Bouton suggestions -->
        <ImageView
            android:id="@+id/suggestionsBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="8dp"
            android:src="@drawable/ic_suggestions"
            android:contentDescription="Suggestions"
            app:tint="@color/white" />
    </LinearLayout>

    <!-- ==================== Zone de chat ==================== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toTopOf="@+id/suggestionsLayout"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout" />

    <!-- ==================== Barre de suggestions ==================== -->
    <HorizontalScrollView
        android:id="@+id/suggestionsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="8dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@+id/inputLayout">

        <LinearLayout
            android:id="@+id/suggestionsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/suggestion1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/suggestion_chip_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="🎬 Recommend a movie"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/suggestion2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/suggestion_chip_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="🔥 Trending now"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/suggestion3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/suggestion_chip_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="🎭 Best actors"
                android:textColor="@color/white"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/suggestion4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:background="@drawable/suggestion_chip_bg"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="14dp"
                android:paddingTop="8dp"
                android:paddingEnd="14dp"
                android:paddingBottom="8dp"
                android:text="🍿 New releases"
                android:textColor="@color/white"
                android:textSize="13sp" />

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ==================== Zone de saisie ==================== -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="12dp"
        android:elevation="12dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Bouton Microphone -->
        <ImageView
            android:id="@+id/micBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_dark"
            android:padding="10dp"
            android:src="@drawable/microphone"
            android:contentDescription="Voice input"
            app:tint="@color/white" />

        <!-- Champ de saisie -->
        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chat_input_background"
            android:hint="Ask me about movies..."
            android:inputType="text|textMultiLine"
            android:maxLines="3"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:textColor="@color/white"
            android:textColorHint="#6A6A8A"
            android:textSize="15sp" />

        <!-- Bouton Envoi -->
        <ImageView
            android:id="@+id/sendBtn"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/send_button_bg"
            android:padding="10dp"
            android:src="@drawable/ic_send"
            android:contentDescription="Send message"
            app:tint="@color/white" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>